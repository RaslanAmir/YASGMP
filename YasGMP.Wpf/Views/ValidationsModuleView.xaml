<UserControl x:Class="YasGMP.Wpf.Views.ValidationsModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:YasGMP.Wpf.Controls"
             xmlns:conv="clr-namespace:YasGMP.Wpf.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="900"
             AutomationProperties.Name="{DynamicResource Module_Validations_Title}"
             ToolTipService.ToolTip="{DynamicResource Module_Validations_Tooltip}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:ResourceStringConverter x:Key="ResourceString" />
    </UserControl.Resources>
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <ItemsControl ItemsSource="{Binding Toolbar}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton Content="{Binding CaptionKey, Converter={StaticResource ResourceString}}"
                                      AutomationProperties.Name="{Binding AutomationNameKey, Converter={StaticResource ResourceString}}"
                                      Command="{Binding Command}"
                                      IsChecked="{Binding IsChecked}"
                                       Margin="0,0,4,0" AutomationProperties.AutomationId="{Binding AutomationIdKey}">
                            <ToggleButton.ToolTip>
                                <ToolTip Content="{Binding ToolTipKey, Converter={StaticResource ResourceString}}" />
                            </ToggleButton.ToolTip>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Separator />
            <Button Content="CFL"
                    AutomationProperties.Name="{DynamicResource Button_CFL}"
                    AutomationProperties.AutomationId="CflButton"
                    ToolTip="{DynamicResource Tooltip_CFL}"
                    Command="{Binding ShowCflCommand}" />
            <controls:GoldenArrowButton Command="{Binding GoldenArrowCommand}"
                                       AutomationProperties.Name="{DynamicResource Button_GoldenArrow}"
                                       AutomationProperties.AutomationId="GoldenArrowButton"
                                       ToolTip="{DynamicResource Tooltip_GoldenArrow}"
                                       Margin="8,0,0,0" />
            <Button Content="{DynamicResource Button_Attach}"
                    AutomationProperties.Name="{DynamicResource Button_Attach}" AutomationProperties.AutomationId="AttachButton"
                    ToolTip="{DynamicResource Tooltip_Attach}"
                    Command="{Binding AttachDocumentCommand}"
                    Margin="8,0,0,0" />
        </ToolBar>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Label_Search}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Width="220"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{DynamicResource Label_Search}"
                         ToolTip="{DynamicResource Tooltip_SearchBox}" />
            </DockPanel>

            <DataGrid Grid.Row="1"
                      Grid.Column="0"
                      ItemsSource="{Binding RecordsView}"
                      SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Margin="0,0,8,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Column_Code}"
                                        Binding="{Binding Code}"
                                        Width="140" />
                    <DataGridTextColumn Header="{DynamicResource Column_Type}"
                                        Binding="{Binding InspectorFields[0].Value}"
                                        Width="140" />
                    <DataGridTextColumn Header="{DynamicResource Column_Status}"
                                        Binding="{Binding Status}"
                                        Width="140" />
                    <DataGridTextColumn Header="{DynamicResource Column_Target}"
                                        Binding="{Binding InspectorFields[2].Value}"
                                        Width="*" />
                </DataGrid.Columns>
                <DataGrid.ToolTip>
                    <ToolTip Content="{DynamicResource Tooltip_RecordsGrid}" />
                </DataGrid.ToolTip>
            </DataGrid>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Padding="12"
                    Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Label_ValidationDetails}"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_ProtocolCode}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Text="{Binding Editor.Code, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_ProtocolCode}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_ProtocolCode}"
                                     ToolTip="{DynamicResource Tooltip_Validations_ProtocolCode}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_Type}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      ItemsSource="{Binding TypeOptions}"
                                      SelectedItem="{Binding Editor.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.Name="{DynamicResource Label_Type}"
                                      AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_Type}"
                                      ToolTip="{DynamicResource Tooltip_Validations_Type}"
                                      IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_Machine}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      ItemsSource="{Binding MachineOptions}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      SelectedValue="{Binding Editor.MachineId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.Name="{DynamicResource Label_Machine}"
                                      AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_Machine}"
                                      ToolTip="{DynamicResource Tooltip_Validations_Machine}"
                                      IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_Component}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="3"
                                      Grid.Column="1"
                                      ItemsSource="{Binding ComponentOptions}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="Name"
                                      SelectedValue="{Binding Editor.ComponentId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.Name="{DynamicResource Label_Component}"
                                      AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_Component}"
                                      ToolTip="{DynamicResource Tooltip_Validations_Component}"
                                      IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_StartDate}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <DatePicker Grid.Row="4"
                                        Grid.Column="1"
                                        SelectedDate="{Binding Editor.DateStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="{DynamicResource Label_StartDate}"
                                        AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_StartDate}"
                                        ToolTip="{DynamicResource Tooltip_Validations_StartDate}"
                                        IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="5"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_EndDate}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <DatePicker Grid.Row="5"
                                        Grid.Column="1"
                                        SelectedDate="{Binding Editor.DateEnd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="{DynamicResource Label_EndDate}"
                                        AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_EndDate}"
                                        ToolTip="{DynamicResource Tooltip_Validations_EndDate}"
                                        IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="6"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_NextDue}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <DatePicker Grid.Row="6"
                                        Grid.Column="1"
                                        SelectedDate="{Binding Editor.NextDue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        AutomationProperties.Name="{DynamicResource Label_NextDue}"
                                        AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_NextDue}"
                                        ToolTip="{DynamicResource Tooltip_Validations_NextDue}"
                                        IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="7"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_Status}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Row="7"
                                      Grid.Column="1"
                                      ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding Editor.Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.Name="{DynamicResource Label_Status}"
                                      AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_Status}"
                                      ToolTip="{DynamicResource Tooltip_Validations_Status}"
                                      IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="8"
                                       Grid.Column="0"
                                       Text="{DynamicResource Label_Documentation}"
                                       Margin="0,0,8,6"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     Text="{Binding Editor.Documentation, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_Documentation}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_Documentation}"
                                     ToolTip="{DynamicResource Tooltip_Validations_Documentation}"
                                     IsEnabled="{Binding IsEditorEnabled}" />
                        </Grid>

                        <TextBlock Text="{DynamicResource Label_Comments}"
                                   Margin="0,0,0,4" />
                        <TextBox Text="{Binding Editor.Comment, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="120"
                                 AutomationProperties.Name="{DynamicResource Label_Comments}"
                                 AutomationProperties.HelpText="{DynamicResource Tooltip_Validations_Comments}"
                                 ToolTip="{DynamicResource Tooltip_Validations_Comments}"
                                 IsEnabled="{Binding IsEditorEnabled}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding ValidationMessages}"
                              Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="• {Binding}" Foreground="DarkRed" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding StatusMessage}"
                           FontStyle="Italic"
                           Foreground="Gray"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>



