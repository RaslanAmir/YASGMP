<UserControl x:Class="YasGMP.Wpf.Views.WarehouseModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:YasGMP.Wpf.Controls"
             xmlns:conv="clr-namespace:YasGMP.Wpf.Converters"
             mc:Ignorable="d"
             d:DesignHeight="480"
             d:DesignWidth="960"
             AutomationProperties.Name="{DynamicResource Module_Warehouse_Title}"
             ToolTipService.ToolTip="{DynamicResource Module_Warehouse_Tooltip}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:ResourceStringConverter x:Key="ResourceString" />
    </UserControl.Resources>
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <ItemsControl ItemsSource="{Binding Toolbar}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton
                            Content="{Binding CaptionKey, Converter={StaticResource ResourceString}}"
                            Command="{Binding Command}"
                            IsChecked="{Binding IsChecked}"
                            Margin="0,0,4,0"
                            AutomationProperties.Name="{Binding AutomationNameKey, Converter={StaticResource ResourceString}}" AutomationProperties.AutomationId="{Binding AutomationIdKey}">
                            <ToggleButton.ToolTip>
                                <ToolTip Content="{Binding ToolTipKey, Converter={StaticResource ResourceString}}" />
                            </ToggleButton.ToolTip>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Separator />
            <Button Content="CFL"
                    AutomationProperties.Name="{DynamicResource Button_CFL}"
                    AutomationProperties.AutomationId="CflButton"
                    ToolTip="{DynamicResource Tooltip_CFL}"
                    Command="{Binding ShowCflCommand}" />
            <Button Content="{DynamicResource Button_Attach}"
                    AutomationProperties.Name="{DynamicResource Button_Attach}" AutomationProperties.AutomationId="AttachButton"
                    ToolTip="{DynamicResource Tooltip_Attach}"
                    Command="{Binding AttachDocumentCommand}"
                    Margin="8,0,0,0" />
            <controls:GoldenArrowButton
                AutomationProperties.Name="{DynamicResource Button_GoldenArrow}"
                AutomationProperties.AutomationId="GoldenArrowButton"
                ToolTip="{DynamicResource Tooltip_GoldenArrow}"
                Command="{Binding GoldenArrowCommand}"
                Margin="8,0,0,0" />
        </ToolBar>
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Label_Search}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Width="220"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{DynamicResource Label_Search}"
                         ToolTip="{DynamicResource Tooltip_SearchBox}" />
            </DockPanel>
            <DataGrid Grid.Row="1"
                      Grid.Column="0"
                      ItemsSource="{Binding RecordsView}"
                      SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      Margin="0,0,8,0">
                <DataGrid.ToolTip>
                    <ToolTip Content="{DynamicResource Tooltip_RecordsGrid}" />
                </DataGrid.ToolTip>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Module_Warehouse_Title}" Binding="{Binding Title}" Width="2*" />
                    <DataGridTextColumn Header="{DynamicResource Column_Location}" Binding="{Binding InspectorFields[0].Value}" Width="2*" />
                    <DataGridTextColumn Header="{DynamicResource Column_Status}" Binding="{Binding Status}" Width="140" />
                </DataGrid.Columns>
            </DataGrid>
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Padding="12"
                    Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                    BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Module_Warehouse_Title}" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{DynamicResource Label_Name}" Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Text="{Binding Editor.Name, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_Name}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_Name}"
                                     ToolTip="{DynamicResource Tooltip_Warehouse_Name}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Text="{DynamicResource Label_Location}" Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding Editor.Location, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_Location}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_Location}"
                                     ToolTip="{DynamicResource Tooltip_Warehouse_Location}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Text="{DynamicResource Label_Status}" Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      ItemsSource="{Binding StatusOptions}"
                                      SelectedItem="{Binding Editor.Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      AutomationProperties.Name="{DynamicResource Label_Status}"
                                      AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_Status}"
                                      ToolTip="{DynamicResource Tooltip_Warehouse_Status}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Text="{DynamicResource Label_Responsible}" Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Text="{Binding Editor.Responsible, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_Responsible}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_Responsible}"
                                     ToolTip="{DynamicResource Tooltip_Warehouse_Responsible}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Text="{DynamicResource Label_QRCode}" Grid.Row="4" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" />
                            <TextBox Grid.Row="4"
                                     Grid.Column="1"
                                     Text="{Binding Editor.QrCode, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_QRCode}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_QrCode}"
                                     ToolTip="{DynamicResource Tooltip_Warehouse_QrCode}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Text="{DynamicResource Label_ClimateMode}" Grid.Row="5" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="1"
                                     Text="{Binding Editor.ClimateMode, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_ClimateMode}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_ClimateMode}"
                                     ToolTip="{DynamicResource Tooltip_Warehouse_ClimateMode}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                <CheckBox Content="{DynamicResource Label_Qualified}"
                                          IsChecked="{Binding Editor.IsQualified, Mode=TwoWay}"
                                          AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_Qualified}"
                                          ToolTip="{DynamicResource Tooltip_Warehouse_Qualified}"
                                          IsEnabled="{Binding IsEditorEnabled}" />
                                <TextBlock Text="{DynamicResource Label_LastQualified}" Margin="16,0,8,0" VerticalAlignment="Center" />
                                <DatePicker SelectedDate="{Binding Editor.LastQualified, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsEnabled="{Binding IsEditorEnabled}" />
                            </StackPanel>

                            <TextBlock Text="{DynamicResource Label_Notes}" Grid.Row="7" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Top" />
                            <TextBox Grid.Row="7"
                                     Grid.Column="1"
                                     Text="{Binding Editor.Note, UpdateSourceTrigger=PropertyChanged}"
                                     AutomationProperties.Name="{DynamicResource Label_Notes}"
                                     AutomationProperties.HelpText="{DynamicResource Tooltip_Warehouse_Notes}"
                                     ToolTip="{DynamicResource Tooltip_Warehouse_Notes}"
                                     AcceptsReturn="True"
                                     Height="60"
                                     TextWrapping="Wrap"
                                     IsEnabled="{Binding IsEditorEnabled}" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ValidationMessages}" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="•" Foreground="DarkRed" Margin="0,0,4,0" />
                                        <TextBlock Text="{Binding}" Foreground="DarkRed" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#1FFFCCCC" Padding="8" Margin="0,12,0,0" CornerRadius="4" Visibility="{Binding HasStockAlerts, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚠" FontSize="16" Margin="0,0,8,0" />
                                <TextBlock Text="{DynamicResource Text_UnderMinimumStock}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <GroupBox Header="{DynamicResource Label_StockSnapshot}" Margin="0,16,0,0">
                            <DataGrid ItemsSource="{Binding StockSnapshot}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" HeadersVisibility="Column" MinHeight="160">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBelowMinimum}" Value="True">
                                                <Setter Property="Foreground" Value="DarkRed" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsAboveMaximum}" Value="True">
                                                <Setter Property="Foreground" Value="DarkGoldenrod" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource Column_Part}" Binding="{Binding PartName}" Width="2*" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Code}" Binding="{Binding PartCode}" Width="120" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Qty}" Binding="{Binding Quantity}" Width="70" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Reserved}" Binding="{Binding Reserved}" Width="80" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Blocked}" Binding="{Binding Blocked}" Width="80" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Min}" Binding="{Binding MinThreshold}" Width="70" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Max}" Binding="{Binding MaxThreshold}" Width="70" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Batch}" Binding="{Binding BatchNumber}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Expiry}" Binding="{Binding ExpiryDate, StringFormat=yyyy-MM-dd}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Header="{DynamicResource Label_RecentMovements}" Margin="0,16,0,0">
                            <DataGrid ItemsSource="{Binding RecentMovements}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" MinHeight="140">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource Column_When}" Binding="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Width="160" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Type}" Binding="{Binding Type}" Width="120" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Qty}" Binding="{Binding Quantity}" Width="70" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Document}" Binding="{Binding RelatedDocument}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource Column_Note}" Binding="{Binding Note}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" FontStyle="Italic" Foreground="Gray" Margin="0,12,0,0" />
        </Grid>
    </DockPanel>
</UserControl>
