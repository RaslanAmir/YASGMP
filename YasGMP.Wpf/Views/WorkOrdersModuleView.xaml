<UserControl x:Class="YasGMP.Wpf.Views.WorkOrdersModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:YasGMP.Wpf.Controls"
             xmlns:conv="clr-namespace:YasGMP.Wpf.Converters"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="600"
             AutomationProperties.Name="{DynamicResource Module_WorkOrders_Title}"
             ToolTipService.ToolTip="{DynamicResource Module_WorkOrders_Tooltip}">
    <UserControl.Resources>
        <conv:ResourceStringConverter x:Key="ResourceString" />
    </UserControl.Resources>
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <ItemsControl ItemsSource="{Binding Toolbar}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton
                            Content="{Binding CaptionKey, Converter={StaticResource ResourceString}}"
                            Command="{Binding Command}"
                            IsChecked="{Binding IsChecked}"
                            Margin="0,0,4,0"
                            AutomationProperties.Name="{Binding AutomationNameKey, Converter={StaticResource ResourceString}}">
                            <ToggleButton.ToolTip>
                                <ToolTip Content="{Binding ToolTipKey, Converter={StaticResource ResourceString}}" />
                            </ToggleButton.ToolTip>
                        </ToggleButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Separator />
            <Button Content="CFL"
                    AutomationProperties.Name="{DynamicResource Button_CFL}"
                    ToolTip="{DynamicResource Tooltip_CFL}"
                    Command="{Binding ShowCflCommand}" />
            <Button Content="{DynamicResource Button_Attach}"
                    AutomationProperties.Name="{DynamicResource Button_Attach}"
                    ToolTip="{DynamicResource Tooltip_Attach}"
                    Command="{Binding AttachDocumentCommand}"
                    Margin="8,0,0,0" />
            <controls:GoldenArrowButton
                AutomationProperties.Name="{DynamicResource Button_GoldenArrow}"
                ToolTip="{DynamicResource Tooltip_GoldenArrow}"
                Command="{Binding GoldenArrowCommand}"
                Margin="8,0,0,0" />
        </ToolBar>
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="{DynamicResource Label_Search}" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Width="220"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="{DynamicResource Label_Search}"
                         ToolTip="{DynamicResource Tooltip_SearchBox}" />
            </DockPanel>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>
                <DataGrid Grid.Column="0"
                          Margin="0,0,12,0"
                          ItemsSource="{Binding RecordsView}"
                          SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.ToolTip>
                        <ToolTip Content="{DynamicResource Tooltip_RecordsGrid}" />
                    </DataGrid.ToolTip>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Column_Code}" Binding="{Binding Code}" Width="120" />
                        <DataGridTextColumn Header="{DynamicResource Column_Title}" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="{DynamicResource Column_Status}" Binding="{Binding Status}" Width="140" />
                        <DataGridTextColumn Header="{DynamicResource Column_Description}" Binding="{Binding Description}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="{DynamicResource Label_WorkOrderDetails}" FontWeight="Bold" FontSize="14" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Label_Title}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,8,12"
                                     Text="{Binding Editor.Title, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource Label_Status}" Margin="8,0,0,4" />
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="8,0,0,12"
                                     Text="{Binding Editor.Status, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Label_Type}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,8,12"
                                     Text="{Binding Editor.Type, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource Label_Priority}" Margin="8,0,0,4" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="8,0,0,12"
                                     Text="{Binding Editor.Priority, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Label_Machine}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="2" Grid.Column="0" Margin="0,0,8,12"
                                     Text="{Binding Editor.MachineId, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{DynamicResource Label_Component}" Margin="8,0,0,4" />
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="8,0,0,12"
                                     Text="{Binding Editor.ComponentId, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Label_RequestedBy}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="3" Grid.Column="0" Margin="0,0,8,12"
                                     Text="{Binding Editor.RequestedById, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{DynamicResource Label_AssignedTo}" Margin="8,0,0,4" />
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="8,0,0,12"
                                     Text="{Binding Editor.AssignedToId, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Label_CreatedBy}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="4" Grid.Column="0" Margin="0,0,8,12"
                                     Text="{Binding Editor.CreatedById, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{DynamicResource Label_DateOpen}" Margin="8,0,0,4" />
                            <DatePicker Grid.Row="4" Grid.Column="1" Margin="8,0,0,12"
                                        SelectedDate="{Binding Editor.DateOpen, Mode=TwoWay}"
                                        IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource Label_DueDate}" Margin="0,0,8,4" />
                            <DatePicker Grid.Row="5" Grid.Column="0" Margin="0,0,8,12"
                                        SelectedDate="{Binding Editor.DueDate, Mode=TwoWay}"
                                        IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{DynamicResource Label_DateClosed}" Margin="8,0,0,4" />
                            <DatePicker Grid.Row="5" Grid.Column="1" Margin="8,0,0,12"
                                        SelectedDate="{Binding Editor.DateClose, Mode=TwoWay}"
                                        IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Label_Result}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                     Text="{Binding Editor.Result, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource Label_TaskDescription}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                     Text="{Binding Editor.TaskDescription, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource Label_Description}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="80"
                                     Text="{Binding Editor.Description, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="{DynamicResource Label_Notes}" Margin="0,0,8,4" />
                            <TextBox Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="80"
                                     Text="{Binding Editor.Notes, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsEditorEnabled}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            <TextBlock Grid.Row="2"
                       Text="{Binding StatusMessage}"
                       FontStyle="Italic"
                       Foreground="Gray"
                       Margin="0,8,0,0" />
        </Grid>
    </DockPanel>
</UserControl>
